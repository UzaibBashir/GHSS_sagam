# Runtime
ENVIRONMENT=development

# Admin auth (change in production)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-123
ADMIN_SESSION_SECRET=replace-with-a-long-random-secret-at-least-32-chars
ADMIN_TOKEN_TTL_SECONDS=28800
ADMIN_FAILED_LOGIN_LIMIT=5
ADMIN_LOCKOUT_SECONDS=300

# Student sessions
STUDENT_TOKEN_TTL_SECONDS=14400

# Rate limiting (per IP)
RATE_LIMIT_WINDOW_SECONDS=60
ADMIN_RATE_LIMIT=8
STUDENT_RATE_LIMIT=10
CONTACT_RATE_LIMIT=5

# Host hardening (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1,.vercel.app

# Optional override. Keep /api for same-origin API usage.
NEXT_PUBLIC_API_URL=/api

# GGHSS-XI-M-101 / medical101
# GGHSS-XI-NM-102 / nonmedical102
# GGHSS-XII-A-103 / arts103

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/?retryWrites=true&w=majority
MONGODB_DB_NAME=ghhs
MONGODB_STATE_COLLECTION=app_state

