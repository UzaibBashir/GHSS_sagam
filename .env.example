# Runtime
ENVIRONMENT=development

# Admin auth (change in production)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-123
# Optional: provide a hashed admin password value generated offline (scrypt$v1$...).
# If ADMIN_PASSWORD is hashed, login verification uses hash compare.
ADMIN_SESSION_SECRET=replace-with-a-long-random-secret-at-least-32-chars
ADMIN_TOKEN_TTL_SECONDS=28800
ADMIN_FAILED_LOGIN_LIMIT=5
ADMIN_LOCKOUT_SECONDS=300

# Student sessions
STUDENT_TOKEN_TTL_SECONDS=14400

# Rate limiting (per IP)
RATE_LIMIT_WINDOW_SECONDS=60
ADMIN_RATE_LIMIT=8
STUDENT_RATE_LIMIT=10
CONTACT_RATE_LIMIT=5
MONITORING_RATE_LIMIT=60
# Optional shared key required by /api/monitoring/events when set.
MONITORING_INGEST_KEY=

# Host hardening (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1,.vercel.app

# Optional override. Keep /api for same-origin API usage.
NEXT_PUBLIC_API_URL=/api

# Optional one-time student bootstrap payload (JSON array), e.g.
# STUDENT_BOOTSTRAP_JSON=[{"rollNumber":"GGHSS-XI-M-101","name":"Student","className":"Class XI","stream":"Medical","password":"replace-me"}]
STUDENT_BOOTSTRAP_JSON=

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/?retryWrites=true&w=majority
MONGODB_DB_NAME=ghhs
MONGODB_STATE_COLLECTION=app_state
DB_OPERATION_TIMEOUT_MS=12000

# Upload storage driver: local | s3
STORAGE_DRIVER=local
STORAGE_PUBLIC_BASE_URL=
S3_BUCKET=
S3_REGION=us-east-1
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=0

# Production safety: keep this 0 in production to avoid silent in-memory fallback.
ALLOW_MEMORY_STORE_FALLBACK=0

